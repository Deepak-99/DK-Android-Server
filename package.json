{
  "name": "dk-hawkshaw-server",
  "version": "1.0.0",
  "description": "Backend server for DK Hawkshaw Android App - Device Management System",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:clean": "node scripts/clean-database.js",
    "db:setup": "node scripts/setup-database.js",
    "db:reset": "npm run db:clean && npm run db:setup",
    "migrate": "npx sequelize-cli db:migrate",
    "rollback": "npx sequelize-cli db:migrate:undo",
    "migrate:all": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:index:check": "node scripts/check-duplicate-indexes.js",
    "db:index:cleanup": "node scripts/remove-duplicate-indexes.js",
    "db:index:fix": "node scripts/remove-duplicate-indexes.js --apply",
    "init-db": "node scripts/init-database.js",
    "init-test-db": "node scripts/init-test-db.js",
    "test": "cross-env NODE_ENV=test node scripts/test.js",
    "test:unit": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:watch": "cross-env NODE_ENV=test jest --watch --detectOpenHandles",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles",
    "test:api": "cross-env NODE_ENV=test jest tests/api/ --detectOpenHandles --forceExit",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration/ --detectOpenHandles --forceExit",
    "test:e2e": "cross-env NODE_ENV=test jest tests/e2e/ --detectOpenHandles --forceExit",
    "pretest": "npm run init-test-db",
    "posttest": "npm run cleanup-test"

  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.7",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-devtools": "^5.91.3",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.3.1",
    "firebase-admin": "^13.4.0",
    "fluent-ffmpeg": "^2.1.3",
    "formik": "^2.4.9",
    "geolib": "^3.3.4",
    "helmet": "^7.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^0.563.0",
    "mediasoup": "^3.19.17",
    "mime-types": "^3.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.19.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "notistack": "^3.0.2",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.13.0",
    "sequelize": "^6.32.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "sonner": "^2.0.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "umzug": "^3.8.2",
    "uuid": "^9.0.0",
    "vcard-creator": "^0.7.2",
    "wavesurfer.js": "^7.12.1",
    "winston": "^3.10.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.1",
    "yamljs": "^0.3.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/supertest": "^6.0.3",
    "@types/yup": "^0.29.14",
    "cross-env": "^7.0.3",
    "fs-extra": "^11.3.1",
    "jest": "^30.1.3",
    "jest-junit": "^16.0.0",
    "jest-mock-axios": "^4.8.0",
    "jest-sonar-reporter": "^2.0.0",
    "nodemon": "^3.0.1",
    "sequelize-cli": "^6.6.3",
    "sqlite3": "^5.0.2",
    "supertest": "^7.1.4"
  },




  "keywords": [
    "device-management",
    "android",
    "backend",
    "api",
    "hawkshaw"
  ],
  "author": "DK Hawkshaw Team",
  "license": "MIT"
}
